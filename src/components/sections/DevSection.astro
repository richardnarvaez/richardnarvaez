---
import BrowserChrome from "../browser/BrowserChrome.astro"
---

<section
  id="dev"
  data-section-motion
  data-section-overlap="hero"
  class="relative z-20 -mt-[calc(8vh+200px)] px-5 sm:px-8 md:-mt-[calc(10vh+200px)]"
>
  <div class="mx-auto max-w-6xl pb-24 pt-[12vh] md:pt-[14vh]">
    <div data-section-reveal>
      <BrowserChrome
        url="richardnarvaez.dev/projects"
        className="rounded-[1.5rem]"
      >
        <div class="orbit-dev-browser-placeholder">
          <div class="orbit-dev-browser-grid">
            <article class="orbit-dev-project-tile orbit-dev-project-tile--wide"></article>
            <article class="orbit-dev-project-tile"></article>
            <article class="orbit-dev-project-tile"></article>
            <article class="orbit-dev-project-tile orbit-dev-project-tile--wide"></article>
          </div>
        </div>
      </BrowserChrome>
    </div>
  </div>
</section>

<style>
  .orbit-dev-browser-placeholder {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(255, 81, 47, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(248, 250, 252, 0.96), rgba(241, 245, 249, 0.92));
    padding: 1rem;
  }

  .orbit-dev-browser-grid {
    display: grid;
    min-height: calc(100vh - 2rem);
    grid-template-columns: 1.35fr 1fr;
    gap: 1rem;
  }

  .orbit-dev-project-tile {
    min-height: 15rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 1.25rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.92));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.65),
      0 18px 40px rgba(148, 163, 184, 0.12);
  }

  .orbit-dev-project-tile--wide {
    min-height: 22rem;
  }

  @media (max-width: 767px) {
    .orbit-dev-browser-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
