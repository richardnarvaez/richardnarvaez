---
import { artPreviewItems } from "../hero/hero.data"
---

<section
  id="art"
  data-art-section-root
  data-section-motion
  class="relative min-h-[220vh] border-t border-white/8 px-5 sm:px-8"
>
  <div class="sticky top-0 flex min-h-dvh items-center">
    <div class="mx-auto w-full max-w-6xl py-24">
      <div data-section-reveal class="flex justify-end">
        <button
          data-art-drawer-open
          type="button"
          class="inline-flex h-11 items-center rounded-full border border-white/14 bg-white/[0.07] px-4 text-sm font-semibold text-white transition-colors duration-300 hover:bg-white/[0.12] focus:outline-none"
        >
          Full list
        </button>
      </div>

      <div data-section-reveal class="art-track-wrap relative mt-6 bg-transparent">
        <div
          data-art-track-viewport
          class="overflow-hidden px-4 py-4 md:px-6 md:py-5"
        >
          <ol data-art-track class="art-track-list flex w-max gap-4 md:gap-5">
            {artPreviewItems.map((item, index) => (
              <li class="art-track-card group w-[min(76vw,20rem)] shrink-0 text-left md:w-[min(28vw,21rem)]">
                <article class="overflow-hidden rounded-[1.45rem] border border-white/10 bg-white/[0.03]">
                  <div class="relative aspect-[4/5] overflow-hidden">
                    <img
                      src={item.src}
                      alt={item.alt}
                      class="size-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                    />
                    <div class="absolute left-4 top-4 rounded-full border border-white/18 bg-black/24 px-2.5 py-1 font-jetbrains text-[10px] tracking-[0.22em] text-white/72 backdrop-blur-md">
                      {(index + 1).toString().padStart(2, "0")}
                    </div>
                    <div class="absolute inset-x-0 bottom-0 p-5">
                      <p class="text-[10px] font-semibold tracking-[0.28em] text-fuchsia-200/90">
                        {item.badge}
                      </p>
                      <h4 class="mt-3 text-xl font-semibold text-white">
                        {item.title}
                      </h4>
                      <p class="mt-2 text-sm leading-6 text-white/68">
                        {item.description}
                      </p>
                    </div>
                  </div>
                </article>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </div>

  <dialog data-art-drawer class="art-drawer">
    <div class="art-drawer__panel">
      <div class="flex items-start justify-between gap-4 px-5 py-5 md:px-6">
        <div class="text-left">
          <p class="font-jetbrains text-[11px] uppercase tracking-[0.28em] text-fuchsia-300">
            Full list
          </p>
          <h3 id="art-drawer-title" class="mt-2 text-xl font-semibold text-white">
            All eight frames in one place.
          </h3>
          <p class="mt-3 max-w-[44ch] text-sm leading-7 text-white/68">
            A clean index of the same sequence shown in the rail.
          </p>
        </div>

        <button
          data-art-drawer-close
          type="button"
          class="inline-flex h-11 items-center rounded-full border border-white/14 bg-white/[0.07] px-4 text-sm font-semibold text-white transition-colors duration-300 hover:bg-white/[0.12] focus:outline-none"
        >
          Close
        </button>
      </div>

      <div class="max-h-[calc(100dvh-7rem)] overflow-y-auto px-5 py-5 md:px-6 md:py-6">
        <ol class="grid grid-cols-2 gap-3 md:gap-4 xl:grid-cols-3">
          {artPreviewItems.map((item, index) => (
            <li class="group text-left">
              <article class="overflow-hidden rounded-[1.4rem] border border-white/10 bg-white/[0.04]">
                <div class="relative aspect-[4/5] overflow-hidden">
                  <img
                    src={item.src}
                    alt={item.alt}
                    class="size-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                  />
                  <div class="absolute left-4 top-4 rounded-full border border-white/18 bg-black/24 px-2.5 py-1 font-jetbrains text-[10px] tracking-[0.22em] text-white/72 backdrop-blur-md">
                    {(index + 1).toString().padStart(2, "0")}
                  </div>
                  <div class="absolute inset-x-0 bottom-0 p-4">
                    <p class="text-[10px] font-semibold tracking-[0.26em] text-fuchsia-200/90">
                      {item.badge}
                    </p>
                    <h4 class="mt-2 text-lg font-semibold text-white">
                      {item.title}
                    </h4>
                    <p class="mt-2 text-sm leading-6 text-white/68">
                      {item.description}
                    </p>
                  </div>
                </div>
              </article>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </dialog>
</section>

<style>
  .art-track-card {
    will-change: transform;
  }

  .art-drawer {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: none;
    height: 100%;
    max-height: none;
    margin: 0;
    border: 0;
    background: transparent;
    padding: 0;
  }

  .art-drawer[open] {
    display: flex;
    align-items: stretch;
    justify-content: flex-end;
  }

  .art-drawer::backdrop {
    background: rgba(2, 6, 23, 0.62);
    backdrop-filter: blur(14px);
  }

  .art-drawer__panel {
    width: min(92vw, 64rem);
    height: 100dvh;
    overflow: hidden;
    border-left: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(10, 13, 22, 0.98);
    box-shadow: -24px 0 80px rgba(0, 0, 0, 0.42);
  }

  @media (max-width: 767px) {
    .art-drawer[open] {
      align-items: flex-end;
    }

    .art-drawer__panel {
      width: 100%;
      height: min(88dvh, 52rem);
      border-left: 0;
      border-top-left-radius: 1.5rem;
      border-top-right-radius: 1.5rem;
    }
  }
</style>

<script>
  const roots = document.querySelectorAll("[data-art-section-root]")

  for (const root of roots) {
    const drawer = root.querySelector("[data-art-drawer]")
    const openButtons = root.querySelectorAll("[data-art-drawer-open]")
    const closeButtons = root.querySelectorAll("[data-art-drawer-close]")

    if (!(drawer instanceof HTMLDialogElement)) continue

    const openDrawer = () => {
      if (!drawer.open) {
        drawer.showModal()
      }
    }

    const closeDrawer = () => {
      if (drawer.open) {
        drawer.close()
      }
    }

    for (const button of openButtons) {
      button.addEventListener("click", openDrawer)
    }

    for (const button of closeButtons) {
      button.addEventListener("click", closeDrawer)
    }

    drawer.addEventListener("click", (event) => {
      if (event.target === drawer) {
        closeDrawer()
      }
    })
  }
</script>
