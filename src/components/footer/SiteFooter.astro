---
import FooterSignature from "./FooterSignature.astro"
---

<footer
  class="px-5 pb-32 pt-16 sm:px-8"
  style="background: var(--page-accent-surface);"
>
  <div class="flex items-center justify-center">
    <div class="relative flex">
      <div id="signature" class="text-white opacity-70">
        <FooterSignature />
      </div>
    </div>
  </div>

  <div class="mb-32 mt-16 flex flex-col items-center justify-center gap-2.5">
    <div class="flex h-9 w-64 items-center justify-center gap-2 rounded-lg border border-slate-800 bg-gradient-to-b from-transparent to-black/20 text-xs font-medium text-neutral-100/80 shadow">
      <p>Cooked with love in</p>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 12 12"
        fill="none"
        class="w-4"
        aria-hidden="true"
      >
        <g clip-path="url(#footer-flag-ec)">
          <path
            d="M0 6C0 2.68631 2.68631 0 6 0C9.31369 0 12 2.68631 12 6L6 6.52174L0 6Z"
            fill="#FFDA44"
          />
          <path
            d="M0.802856 9.00002C1.84032 10.7934 3.77916 12 5.99998 12C8.2208 12 10.1596 10.7934 11.1971 9.00002L5.99998 8.6087L0.802856 9.00002Z"
            fill="#D80027"
          />
          <path
            d="M11.1971 9C11.7076 8.11748 12 7.09291 12 6H0C0 7.09291 0.292359 8.11748 0.802875 9H11.1971Z"
            fill="#0052B4"
          />
          <path
            d="M6.00003 8.08692C7.15262 8.08692 8.08698 7.15256 8.08698 5.99997C8.08698 4.84738 7.15262 3.91302 6.00003 3.91302C4.84744 3.91302 3.91309 4.84738 3.91309 5.99997C3.91309 7.15256 4.84744 8.08692 6.00003 8.08692Z"
            fill="#FFDA44"
          />
          <path
            d="M6.00002 7.30431C5.2808 7.30431 4.69568 6.71917 4.69568 5.99997V5.21737C4.69568 4.49814 5.28082 3.91302 6.00002 3.91302C6.71923 3.91302 7.30437 4.49817 7.30437 5.21737V5.99997C7.30437 6.7192 6.71925 7.30431 6.00002 7.30431Z"
            fill="#338AF3"
          />
          <path
            d="M8.08696 2.86958H6.52174C6.52174 2.58144 6.28813 2.34784 5.99999 2.34784C5.71185 2.34784 5.47825 2.58144 5.47825 2.86958H3.91302C3.91302 3.15775 4.16402 3.39132 4.45213 3.39132H4.43477C4.43477 3.67949 4.66835 3.91307 4.95651 3.91307C4.95651 4.20123 5.19009 4.43481 5.47825 4.43481H6.52174C6.8099 4.43481 7.04348 4.20123 7.04348 3.91307C7.33164 3.91307 7.56522 3.67949 7.56522 3.39132H7.54785C7.83599 3.39132 8.08696 3.15772 8.08696 2.86958Z"
            fill="black"
          />
        </g>
        <defs>
          <clipPath id="footer-flag-ec">
            <rect width="12" height="12" fill="white" />
          </clipPath>
        </defs>
      </svg>
      <span>with</span>
      <img
        src="https://astro.build/assets/press/astro-icon-light-gradient.svg"
        alt="Astro"
        class="h-4 w-4"
        loading="lazy"
      />
    </div>

    <div class="mt-3 text-xs font-medium leading-none text-white/30">
      © richard vinueza - 2024
    </div>
  </div>
</footer>
