---
import ArrowFigma from "../icons/ArrowFigma.astro";
import VercelColorIcon from "../icons/VercelColorIcon.astro";
import packageJson from "../../../package.json";
import { heroOrbitNodes } from "./hero.data";

const githubUrl = "https://github.com/richardnarvaez/";
const instagramUrl = "https://www.instagram.com/richard.vinueza/";
const linkedinUrl = "https://www.linkedin.com/in/richard-vinueza/";
const instagramIconSvg =
  '<svg viewBox="0 0 24 24" width="18" height="18" class="hero-device-contact-link__svg" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>';
const linkedinIconSvg =
  '<svg viewBox="0 0 256 256" width="18" height="18" class="hero-device-contact-link__svg" fill="currentColor" aria-hidden="true"><path d="M218.123 218.127h-37.931v-59.403c0-14.165-.253-32.4-19.728-32.4-19.756 0-22.779 15.434-22.779 31.369v60.43h-37.93V95.967h36.413v16.694h.51a39.907 39.907 0 0 1 35.928-19.733c38.445 0 45.533 25.288 45.533 58.186l-.016 67.013ZM56.955 79.27c-12.157.002-22.014-9.852-22.016-22.009-.002-12.157 9.851-22.014 22.008-22.016 12.157-.003 22.014 9.851 22.016 22.008A22.013 22.013 0 0 1 56.955 79.27m18.966 138.858H37.95V95.967h37.97v122.16ZM237.033.018H18.89C8.58-.098.125 8.161-.001 18.471v219.053c.122 10.315 8.576 18.582 18.89 18.474h218.144c10.336.128 18.823-8.139 18.966-18.474V18.454c-.147-10.33-8.635-18.588-18.966-18.453"/></svg>';
const githubIconSvg =
  '<svg viewBox="0 0 512 512" width="18" height="18" class="hero-device-contact-link__svg" fill="currentColor" aria-hidden="true"><path clip-rule="evenodd" d="M296.133,354.174c49.885-5.891,102.942-24.029,102.942-110.192c0-24.49-8.624-44.448-22.67-59.869c2.266-5.89,9.515-28.114-2.734-58.947c0,0-18.139-5.898-60.759,22.669c-18.139-4.983-38.09-8.163-56.682-8.163c-19.053,0-39.011,3.18-56.697,8.163c-43.082-28.567-61.22-22.669-61.22-22.669c-12.241,30.833-4.983,53.057-2.718,58.947c-14.061,15.42-22.677,35.379-22.677,59.869c0,86.163,53.057,104.301,102.942,110.192c-6.344,5.452-12.241,15.873-14.507,30.387c-12.702,5.438-45.808,15.873-65.758-18.592c0,0-11.795-21.31-34.012-22.669c0,0-22.224-0.453-1.813,13.592c0,0,14.96,6.812,24.943,32.653c0,0,13.6,43.089,76.179,29.48v38.543c0,5.906-4.53,12.702-15.865,10.89C96.139,438.977,32.2,354.626,32.2,255.77c0-123.807,100.216-224.022,224.03-224.022c123.347,0,224.023,100.216,223.57,224.022c0,98.856-63.946,182.754-152.828,212.688c-11.342,2.266-15.873-4.53-15.873-10.89V395.45C311.1,374.577,304.288,360.985,296.133,354.174L296.133,354.174z M512,256.23C512,114.73,397.263,0,256.23,0C114.73,0,0,114.73,0,256.23C0,397.263,114.73,512,256.23,512C397.263,512,512,397.263,512,256.23L512,256.23z" fill-rule="evenodd"/></svg>';
const contactLinks = [
  {
    id: "instagram",
    label: "Instagram",
    href: instagramUrl,
    iconSvg: instagramIconSvg,
    surfaceClass: "bg-[linear-gradient(135deg,#f97316,#ec4899_56%,#7c3aed)]",
    glyphClass: "scale-[0.94]",
  },
  {
    id: "linkedin",
    label: "LinkedIn",
    href: linkedinUrl,
    iconSvg: linkedinIconSvg,
    surfaceClass: "bg-[linear-gradient(135deg,#38bdf8,#2563eb)]",
    glyphClass: "scale-[0.72] -translate-y-[0.015rem]",
  },
  {
    id: "github",
    label: "GitHub",
    href: githubUrl,
    iconSvg: githubIconSvg,
    surfaceClass: "bg-[linear-gradient(135deg,#334155,#0f172a)]",
    glyphClass: "scale-[0.84]",
  },
] as const;

const projectVersionLabel = `v${packageJson.version ?? "0.0.0"}`;

const notchIdleRows = [
  "033300000000",
  "300003330000",
  "333343303333",
  "333333333333",
  "003200003200",
  "003320003320",
] as const;

const notchPixels = notchIdleRows.flatMap((row, rowIndex) =>
  Array.from(row).map((tone, columnIndex) => ({
    row: rowIndex,
    column: columnIndex,
    tone,
    active: tone !== "0",
    delay: (rowIndex * row.length + columnIndex) * 0.028,
  })),
);

function buildBoardSprite(rows: readonly string[]) {
  return {
    columns: rows[0]?.length ?? 0,
    rows: rows.length,
    pixels: rows.flatMap((row, rowIndex) =>
      Array.from(row).map((tone, columnIndex) => ({
        row: rowIndex,
        column: columnIndex,
        tone,
        active: tone !== "0",
      })),
    ),
  };
}

function buildFoodSprite(rows: readonly string[]) {
  return {
    columns: rows[0]?.length ?? 0,
    rows: rows.length,
    pixels: rows.flatMap((row, rowIndex) =>
      Array.from(row).map((tone, columnIndex) => ({
        row: rowIndex,
        column: columnIndex,
        tone,
        active: tone !== "0",
      })),
    ),
  };
}

const foodItems = [
  {
    id: "fish",
    label: "Fish",
    sprite: buildFoodSprite([
      "000111000010",
      "001111100110",
      "110441111111",
      "011433113311",
      "113111100110",
      "001111000010",
    ]),
  },
  {
    id: "pig",
    label: "Pig",
    sprite: buildFoodSprite([
      "087777777780",
      "877777777778",
      "877977779778",
      "077444444770",
      "077494494770",
      "007444444700",
    ]),
  },
  {
    id: "goose",
    label: "Goose",
    sprite: buildFoodSprite([
      "000666600000",
      "006055560000",
      "333556555560",
      "333556665560",
      "006555555600",
      "000666660000",
    ]),
  },
] as const;

const contactBoardCoco = buildBoardSprite([
  "033300000000",
  "300003330333",
  "333343303550",
  "333333333333",
  "003200003200",
  "003320003320",
]);

const contactBoardAnimals = foodItems.map((item) => ({
  ...item,
  columns: item.sprite.columns,
  rows: item.sprite.rows,
  pixels: item.sprite.pixels.map((pixel) => {
    const ledStyle =
      pixel.tone === "1"
        ? "background:#38bdf8;"
        : pixel.tone === "2"
          ? "background:#7dd3fc;"
          : pixel.tone === "3"
            ? "background:#f59e0b;"
            : pixel.tone === "4"
              ? "background:#f472b6;"
              : pixel.tone === "5"
                ? "background:#f8fafc;"
                : pixel.tone === "6"
                  ? "background:#94a3b8;"
                  : pixel.tone === "7"
                    ? "background:#fbcfe8;"
                    : pixel.tone === "8"
                      ? "background:#fb7185;"
                      : pixel.tone === "9"
                        ? "background:#0f172a;"
                        : "";

    return { ...pixel, ledStyle };
  }),
}));

const contactBoardCocoPixels = contactBoardCoco.pixels.map((pixel) => {
  const ledStyle =
    pixel.tone === "1"
      ? "background:#166534;"
      : pixel.tone === "2"
        ? "background:#22c55e;"
        : pixel.tone === "3"
          ? "background:#4ade80;"
          : pixel.tone === "4"
            ? "background:#bbf7d0;"
            : pixel.tone === "5"
              ? "background:#ef4444;"
              : pixel.tone === "8"
                ? "background:#ef4444;"
                : "";

  return { ...pixel, ledStyle };
});
---

<section id="header" data-hero-root class="relative text-center">
  <div
    data-hero-stage
    class="-mb-dvh sticky top-0 isolate z-10 flex h-dvh w-full flex-col items-center justify-center gap-4 overflow-hidden text-center"
  >
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <img
        data-hero-image
        src="/images/home/bg-header.jpg"
        width="720"
        height="720"
        loading="eager"
        fetchpriority="high"
        alt="Background - Richard Narvaez profile"
        class="absolute inset-0 size-full transform-gpu object-cover [backface-visibility:hidden] [will-change:transform,opacity,filter]"
        style="opacity: 0"
      />
    </div>

    <div data-title class="w-full max-w-5xl">
      <div
        class="relative z-20 flex w-full flex-col items-center justify-center gap-4"
      >
        <h1 class="sr-only">
          Richard Narvaez - Creative Human - software, sketches and passport
        </h1>

        <h2
          class="font-barlow z-10 flex max-w-3xl origin-center scale-[0.70] flex-col text-center text-8xl font-extrabold sm:scale-[0.82] md:scale-[1.2]"
        >
          <span
            data-title-piece
            class="font-playfair text-[0.74em] font-medium italic tracking-normal text-white opacity-90 md:text-[0.72em]"
            style="opacity: 0"
          >
            Creative
          </span>

          <span
            data-title-piece
            class="relative z-10 mt-6 bg-black/30 px-4 py-1 backdrop-blur-sm"
            style="opacity: 0"
          >
            <div
              class="border-h absolute -left-10 right-0 top-[-2px] h-1 w-[124%]"
            >
            </div>
            <div
              class="border-h absolute -bottom-px -left-20 right-0 h-1 w-[130%]"
            >
            </div>
            <div class="border-v absolute -top-8 left-[-2px] h-[150%] w-1">
            </div>
            <div class="border-v absolute -bottom-12 -right-px h-[170%] w-1">
            </div>

            <div
              class="absolute -left-1.5 -top-1.5 size-3 border-2 border-gray-400 bg-white"
            >
            </div>
            <div
              class="absolute -bottom-1.5 -left-1.5 size-3 border-2 border-gray-400 bg-white"
            >
            </div>
            <div
              class="absolute -bottom-1.5 -right-1.5 size-3 border-2 border-gray-400 bg-white"
            >
            </div>
            <div
              class="absolute -right-1.5 -top-1.5 size-3 border-2 border-gray-400 bg-white shadow"
            >
            </div>

            <p class="pb-2 text-[1.08em] opacity-80 md:text-[1.04em]">
              HUM<span class="opacity-20">A</span>N
            </p>

            <div
              class="absolute -bottom-6 -right-12 z-50 hidden animate-float md:block"
            >
              <div class="hero-ai-cursor">
                <div class="hero-ai-cursor__arrow">
                  <ArrowFigma />
                </div>
                <div class="hero-ai-cursor__box">
                  <div class="hero-ai-cursor__corners">
                    <span></span><span></span><span></span><span></span>
                  </div>
                  <p>AI</p>
                </div>
              </div>
              <h3
                class="relative z-50 mt-3 rounded-md bg-gray-50 px-4 py-2 text-center text-xs font-semibold text-black"
              >
                Richard Narvaez
              </h3>
            </div>
          </span>

          <div
            data-title-piece
            class="font-playfair mb-3 mt-6 flex items-center justify-center gap-4 text-[2.15rem] font-light italic text-gray-300 sm:text-[2.35rem] md:text-[2.3rem]"
            style="opacity: 0"
          >
            <div class="h-[2px] w-12 rounded-full bg-gray-400/70"></div>
            <span class="block pb-2 leading-[0.5]">thinking...</span>
            <div class="h-[2px] w-12 rounded-full bg-gray-400/70"></div>
          </div>

          <span
            data-title-piece
            class="text-[4.1rem] leading-none text-[#FF512F] sm:text-[4.6rem] md:text-[3.4rem]"
            style="opacity: 0"
          >
            -
          </span>
        </h2>
      </div>
    </div>

    <div
      data-orbit-scene
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 z-10 flex items-center justify-center"
      style="opacity: 0"
    >
      <div class="absolute inset-0 flex items-center justify-center px-4">
        <div class="hero-orbit-field">
          <div
            class="absolute left-1/2 top-1/2 aspect-square h-[200%] -translate-x-1/2 -translate-y-1/2"
          >
            <div data-orbit-graphic class="absolute inset-0 hidden md:block">
              <svg
                viewBox="0 0 1251 1251"
                class="absolute inset-0 size-full"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M625.5 910.5C782.901 910.5 910.5 782.901 910.5 625.5C910.5 468.099 782.901 340.5 625.5 340.5C468.099 340.5 340.5 468.099 340.5 625.5C340.5 782.901 468.099 910.5 625.5 910.5Z"
                  stroke="white"
                  stroke-opacity="0.06"></path>
                <path
                  d="M625.5 1020.5C843.652 1020.5 1020.5 843.652 1020.5 625.5C1020.5 407.348 843.652 230.5 625.5 230.5C407.348 230.5 230.5 407.348 230.5 625.5C230.5 843.652 407.348 1020.5 625.5 1020.5Z"
                  stroke="white"
                  stroke-opacity="0.05"></path>
                <path
                  d="M625.5 1130.5C904.404 1130.5 1130.5 904.404 1130.5 625.5C1130.5 346.596 904.404 120.5 625.5 120.5C346.596 120.5 120.5 346.596 120.5 625.5C120.5 904.404 346.596 1130.5 625.5 1130.5Z"
                  stroke="white"
                  stroke-opacity="0.04"></path>
                <path
                  d="M625.5 1250.5C970.678 1250.5 1250.5 970.678 1250.5 625.5C1250.5 280.322 970.678 0.5 625.5 0.5C280.322 0.5 0.5 280.322 0.5 625.5C0.5 970.678 280.322 1250.5 625.5 1250.5Z"
                  stroke="white"
                  stroke-opacity="0.04"></path>
                <path
                  d="M244.5 730.5C226 660 231.5 630.338 272.353 625.726C313.206 621.113 338.5 624 344 581C349.501 538.001 373 490 383.001 475.501"
                  stroke="url(#paint0_linear_hero)"
                  stroke-opacity="0.32"></path>
                <path
                  d="M865.677 312.15C923.684 356.815 937.421 383.742 907.43 412.424C877.44 441.106 855.357 454.303 877.256 491.823C899.155 529.344 909.658 581.859 910.5 599.5"
                  stroke="url(#paint1_linear_hero)"
                  stroke-opacity="0.32"></path>
                <path
                  d="M1069 867.999C1036.5 928.295 1011.43 946.924 980.663 928.294C949.9 909.664 927.324 887.958 894 915.5C860.677 943.041 826.238 970.579 809.501 975.5"
                  stroke="url(#paint2_linear_hero)"
                  stroke-opacity="0.32"></path>
                <path
                  d="M475.949 142.65C541.625 123.198 572.513 127.85 580.985 162.803C589.457 197.756 585.975 225.279 629 229.5C672.025 233.721 721.712 238.597 737.001 247"
                  stroke="url(#paint3_linear_hero)"
                  stroke-opacity="0.32"></path>
                <defs>
                  <linearGradient
                    id="paint0_linear_hero"
                    x1="308"
                    y1="553"
                    x2="255.414"
                    y2="714.876"
                    gradientUnits="userSpaceOnUse"
                  >
                    <stop stop-color="white" stop-opacity="0"></stop>
                    <stop offset="0.5" stop-color="white" stop-opacity="1"
                    ></stop>
                    <stop offset="1" stop-color="white" stop-opacity="0"></stop>
                  </linearGradient>
                  <linearGradient
                    id="paint1_linear_hero"
                    x1="923.309"
                    y1="492.016"
                    x2="866.452"
                    y2="331.251"
                    gradientUnits="userSpaceOnUse"
                  >
                    <stop stop-color="white" stop-opacity="0"></stop>
                    <stop offset="0.5" stop-color="white" stop-opacity="1"
                    ></stop>
                    <stop offset="1" stop-color="white" stop-opacity="0"></stop>
                  </linearGradient>
                  <linearGradient
                    id="paint2_linear_hero"
                    x1="906.513"
                    y1="960.753"
                    x2="1053.49"
                    y2="874.153"
                    gradientUnits="userSpaceOnUse"
                  >
                    <stop stop-color="white" stop-opacity="0"></stop>
                    <stop offset="0.5" stop-color="white" stop-opacity="1"
                    ></stop>
                    <stop offset="1" stop-color="white" stop-opacity="0"></stop>
                  </linearGradient>
                  <linearGradient
                    id="paint3_linear_hero"
                    x1="656.279"
                    y1="192.517"
                    x2="491.251"
                    y2="149.317"
                    gradientUnits="userSpaceOnUse"
                  >
                    <stop stop-color="white" stop-opacity="0"></stop>
                    <stop offset="0.5" stop-color="white" stop-opacity="1"
                    ></stop>
                    <stop offset="1" stop-color="white" stop-opacity="0"></stop>
                  </linearGradient>
                </defs>
              </svg>
            </div>
          </div>

          {
            heroOrbitNodes.map((node) => (
              <div
                data-orbit-origin-node
                class="hero-orbit-node"
                data-cluster-left={node.cluster.left}
                data-cluster-top={node.cluster.top}
                data-cluster-scale={node.cluster.scale ?? 1}
                style={`left:${node.origin.left}%;top:${node.origin.top}%;`}
              >
                <div class="hero-orbit-node__inner">
                  {node.kind === "icon" && (
                    <div class="icon-bubble">
                      {node.key === "vercel" ? (
                        <span class="vercel-mark-bubble">
                          <VercelColorIcon
                            width="14"
                            height="14"
                            class="size-3.5"
                            aria-hidden="true"
                          />
                        </span>
                      ) : (
                        <img
                          src={node.assets[0].src}
                          alt={node.assets[0].alt}
                          class={
                            node.assets[0].className ?? "size-6 object-contain"
                          }
                        />
                      )}
                    </div>
                  )}

                  {node.kind === "cover" && (
                    <div class="cover-logo-bubble">
                      <img
                        src={node.assets[0].src}
                        alt={node.assets[0].alt}
                        class="size-full object-cover"
                      />
                    </div>
                  )}

                  {(node.kind === "brand-cycle" ||
                    node.kind === "brand-cycle-wide") && (
                    <div
                      class:list={[
                        "brand-cycle-bubble",
                        node.kind === "brand-cycle-wide" &&
                          "brand-cycle-bubble--wide",
                      ]}
                    >
                      {node.assets.map((asset) => (
                        <span class="brand-cycle-item">
                          <img
                            src={asset.src}
                            alt={asset.alt}
                            class={asset.className ?? "size-6 object-contain"}
                          />
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))
          }

          <div data-orbit-cluster-layer class="hero-cluster-layer">
            <div data-orbit-cluster class="hero-cluster-shell">
              <div data-orbit-avatar class="hero-cluster-avatar">
                <img
                  src="/images/avatars/richard.jpg"
                  alt="Richard Narvaez"
                  class="size-full object-cover"
                />
              </div>
              <div data-orbit-meta class="hero-cluster-meta">
                <p class="hero-cluster-meta__name">Richard Vinueza</p>
                <p class="hero-cluster-meta__role mt-6">
                  Product Engineer, Madrid - Spain
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 bottom-0 z-[15] h-[20vh] bg-gradient-to-t from-[hsl(244,31%,10%)] via-[hsl(244,31%,10%)]/50 to-transparent"
    >
    </div>

    <div data-hero-device-frame aria-hidden="true" class="hero-device-frame">
      <div data-hero-device-notch class="hero-device-top-shell">
        <svg
          data-hero-device-notch-svg
          viewBox="0 0 161 24"
          class="hero-device-top-shell__svg"
          preserveAspectRatio="xMidYMin meet"
        >
          <path
            data-hero-device-notch-path
            d="M0 0V2.01331H12.1115C16.5298 2.01331 20.1115 5.59504 20.1115 10.0133V15.3078C20.1115 19.7261 23.6932 23.3078 28.1115 23.3078H135.146C139.565 23.3078 143.146 19.7261 143.146 15.3078V10.0133C143.146 5.59503 146.728 2.01331 151.146 2.01331H160.892V0H0Z"
            fill="var(--page-accent-surface)"></path>
        </svg>
        <div class="hero-device-top-shell__content">
          <div class="hero-device-top-shell__row">
            <div class="hero-device-top-shell__lead justify-between">
              <div class="flex items-center gap-[0.42rem]">
                <div
                  data-notch-sprite
                  class="hero-device-pixel-grid"
                  data-notch-mode="ambient"
                  aria-hidden="true"
                >
                  {
                    notchPixels.map((pixel) => (
                      <span
                        class:list={[
                          "hero-device-pixel",
                          pixel.active && "hero-device-pixel--active",
                          pixel.tone === "1" && "hero-device-pixel--tone-1",
                          pixel.tone === "2" && "hero-device-pixel--tone-2",
                          pixel.tone === "3" && "hero-device-pixel--tone-3",
                          pixel.tone === "4" && "hero-device-pixel--tone-eye",
                          pixel.tone === "5" &&
                            "hero-device-pixel--tone-tongue",
                          pixel.tone === "8" &&
                            "hero-device-pixel--tone-eye-alert",
                        ]}
                        data-notch-pixel
                        data-notch-row={pixel.row}
                        data-notch-column={pixel.column}
                        style={`--pixel-delay:${pixel.delay}s;`}
                      />
                    ))
                  }
                </div>
                <div class="hero-device-top-shell__identity">
                  <span
                    class="hero-device-top-shell__identity-divider"
                    aria-hidden="true">|</span
                  >
                  <div class="hero-device-contact-meta">
                    <span class="hero-device-contact-name"
                      >Interactive Pet (<span data-notch-food-counter>0</span
                      >/3)</span
                    >
                  </div>
                </div>
              </div>

              <div class="hero-device-food-rail pr-2">
                {
                  contactBoardAnimals.map((creature) => (
                    <button
                      type="button"
                      class="inline-flex cursor-pointer border-0 bg-transparent p-0 items-center justify-center focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-sky-200/70"
                      data-notch-food-item
                      title={creature.label}
